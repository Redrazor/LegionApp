# Production build env for the Vercel frontend.
# Set these as Environment Variables in the Vercel project (Settings → Environment
# Variables) — Vite inlines VITE_* at build time. Copy to `.env.production` for a
# local production build. Fill in the URLs once Render + Firebase are created.

# Render backend (Express API + socket.io). No trailing slash.
VITE_API_BASE=https://legionapp-api.onrender.com

# Firebase image CDN root (hosts public/images-compressed). No trailing slash.
VITE_IMAGE_BASE=https://legionapp-images.web.app

# socket.io URL for the future Play feature (usually same as VITE_API_BASE).
VITE_WS_URL=https://legionapp-api.onrender.com
