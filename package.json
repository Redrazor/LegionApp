    "og": "tsx scripts/generate-og.ts",
    "audit:keywords": "tsx scripts/audit-keywords.ts",
    "build": "npm run generate:sitemap && vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "scrape": "tsx scraper/scrape.ts",
    "icons": "tsx scripts/generate-icons.ts",
    "images:compress": "tsx scripts/compress-images.ts",
    "images:deploy": "firebase deploy --only hosting",
    "portraits": "tsx scraper/portraits.ts",
    "portraits:validate": "tsx scripts/generate-portrait-validation.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "seed": "tsx server/db/seed.ts",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "keywords": "tsx scraper/keywords.ts",
    "upgrade-weapons": "tsx scraper/upgradeWeapons.ts",
    "amg:fetch": "tsx scraper/amgDocs.ts",
    "amg:extract": "tsx scraper/amgExtract.ts",
    "amg:apply": "tsx scraper/amgApply.ts",
    "amg:origins": "tsx scripts/generate-card-origins.ts",
    "images:validate": "tsx scripts/generate-image-validation.ts",
    "amg:extras": "tsx scraper/amgExtras.ts",
