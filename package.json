    "amg:p7c": "tsx scripts/build-p7c-commands.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vueuse/head": "^2.0.0",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
