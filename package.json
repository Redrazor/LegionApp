    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.6",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^17.3.1",
    "sharp": "^0.35.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.1.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.6",
    "vue-tsc": "^2.2.0"
